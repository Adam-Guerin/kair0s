    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^8.2.2",
    "oxfmt": "0.33.0",
    "oxlint": "^1.48.0",
    "oxlint-tsgolint": "^0.14.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
