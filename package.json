{
  "name": "kair0s",
  "version": "1.0.0",
  "description": "Kair0s - AI Gateway with Unified Interface",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:ui\" \"pnpm tauri dev\"",
    "dev:ui": "vite",
    "dev:gateway": "cd ../openclaw && pnpm gateway:dev",
    "build": "pnpm build:ui && pnpm tauri build",
    "build:ui": "tsc && vite build",
    "build:gateway": "cd ../openclaw && pnpm build",
    "tauri": "tauri",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "oxlint --type-aware && tsc --noEmit",
    "format": "oxfmt --write"
  },
  "dependencies": {
    "@lit-labs/signals": "^0.1.3",
    "@lit/context": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.15",
